NODE_ENV=development

#== APP
PORT=3000
TRANSPORT_PORT=8080
JWT_EXPIRATION_TIME=3600
FALLBACK_LANGUAGE=en
ENABLE_ORM_LOGS=true
ENABLE_DOCUMENTATION=true
ENABLE_MORGAN=false
LOG_LEVEL=debug
API_VERSION=v1.0.0
APP_NAME=API Boilerplate
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

#== JWT Auth (RS256)
# Generate a fresh key pair before running in any non-throwaway environment:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
# Encode as a single line with literal \n separators (the values below are placeholders).
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_YOUR_PUBLIC_KEY\n-----END PUBLIC KEY-----

#== Database (PostgreSQL)
DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=api_boilerplate
DB_SYNCHRONIZE=false

#== S3 Storage (MinIO local / AWS S3 in cloud)
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_PUBLIC_URL=http://localhost:9000
AWS_S3_ACCESS_KEY_ID=minioadmin
AWS_S3_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET_REGION=us-east-1
AWS_S3_API_VERSION=2010-12-01
AWS_S3_BUCKET_NAME=api-boilerplate
AWS_S3_FORCE_PATH_STYLE=true

#== MinIO root creds (used by docker-compose-local)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

#== NATS (optional microservice transport)
NATS_ENABLED=false
NATS_HOST=localhost
NATS_PORT=4222

#== Redis
REDIS_CACHE_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

#== BullMQ
BULLMQ_DEFAULT_ATTEMPTS=3
BULLMQ_BACKOFF_DELAY=5000

#== Throttler
THROTTLER_TTL=1m
THROTTLER_LIMIT=10

#== PGAdmin (used by docker-compose-local)
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

#== Mail (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
MAIL_DEFAULT_EMAIL=noreply@example.com
MAIL_DEFAULT_NAME=API Boilerplate
FRONTEND_DOMAIN=http://localhost:5173

#== Two-Factor Authentication
ENCRYPTION_KEY=generate_with_node_-e_console.log_require_crypto_randomBytes_32_toString_hex
TWO_FACTOR_ISSUER=API Boilerplate
TWO_FACTOR_CODE_DIGITS=6
TWO_FACTOR_VALIDITY_WINDOW=1
RECOVERY_CODES_COUNT=10

#== Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

#== Monitoring & Alerting
ALERT_EMAIL_TO=devops@example.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/XXX/XXX
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://localhost:3100

#== Cloudflare Turnstile (captcha)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

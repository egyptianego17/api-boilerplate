{
  "id": null,
  "uid": "api-boilerplate-logs-explorer",
  "title": "Logs Explorer",
  "description": "Log exploration, filtering by level, and request tracing by requestId",
  "version": 1,
  "schemaVersion": 39,
  "style": "dark",
  "editable": true,
  "graphTooltip": 0,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "30s",
  "tags": ["api-boilerplate", "logs", "loki"],
  "annotations": { "list": [] },
  "links": [
    {
      "title": "API Overview",
      "type": "link",
      "url": "/d/api-boilerplate-overview",
      "icon": "dashboard",
      "targetBlank": false
    },
    {
      "title": "Infrastructure",
      "type": "link",
      "url": "/d/api-boilerplate-infrastructure",
      "icon": "dashboard",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "app",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(app)",
        "current": { "text": "api-boilerplate", "value": "api-boilerplate" },
        "refresh": 2,
        "includeAll": false,
        "sort": 1,
        "updateIntervalSeconds": 300
      },
      {
        "name": "level",
        "type": "custom",
        "query": "trace,debug,info,warn,error,fatal",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "sort": 0
      },
      {
        "name": "search",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "label": "Search / RequestID"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "panels": [
    {
      "title": "Logs / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"$app\"}[1m]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Total Logs (range)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"$app\"}[$__range]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"$app\"} | json | level=~\"error|fatal\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Warnings",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"$app\"} | json | level=\"warn\" [$__range]))",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "title": "Log Volume by Level",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 80 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "yellow", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "debug" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "blue", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "stacking": "normal",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({app=\"$app\"} | json | level != \"\" [$__interval]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Log Volume Trend",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": true,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "yellow", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "debug" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "blue", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({app=\"$app\"} | json | level != \"\" [$__interval]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Filtered Logs",
      "description": "Filter by level dropdown and search box above. Expand a row to see all fields.",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{app=\"$app\"} | json | level=~\"$level\" |~ \"$search\"",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Request Trace",
      "description": "Paste a requestId into the Search box above to see all logs from that request",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Ascending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{app=\"$app\"} | json | requestId=~\"$search\" | requestId != \"\"",
          "refId": "A"
        }
      ]
    }
  ]
}

{
  "id": null,
  "uid": "api-boilerplate-infrastructure",
  "title": "Infrastructure",
  "description": "Node.js runtime health: memory, GC, event loop, and BullMQ queue metrics",
  "version": 1,
  "schemaVersion": 39,
  "style": "dark",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "30s",
  "tags": ["api-boilerplate", "infrastructure", "nodejs"],
  "annotations": { "list": [] },
  "links": [
    {
      "title": "API Overview",
      "type": "link",
      "url": "/d/api-boilerplate-overview",
      "icon": "dashboard",
      "targetBlank": false
    },
    {
      "title": "Logs Explorer",
      "type": "link",
      "url": "/d/api-boilerplate-logs-explorer",
      "icon": "dashboard",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(process_start_time_seconds, job)",
        "current": { "text": "api-boilerplate", "value": "api-boilerplate" },
        "refresh": 2,
        "includeAll": false,
        "sort": 1,
        "updateIntervalSeconds": 300
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "panels": [
    {
      "title": "Process Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"$job\"}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "CPU Usage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          },
          "unit": "percentunit",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"$job\"}[$__rate_interval])",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "RSS Memory",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 268435456 },
              { "color": "orange", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          },
          "unit": "bytes",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"$job\"}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Open File Descriptors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 900 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "process_open_fds{job=\"$job\"}",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "title": "Heap Memory Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "pointSize": 5,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"$job\"}",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=\"$job\"}",
          "legendFormat": "Heap Total",
          "refId": "B"
        },
        {
          "expr": "nodejs_external_memory_bytes{job=\"$job\"}",
          "legendFormat": "External",
          "refId": "C"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"$job\"}",
          "legendFormat": "RSS",
          "refId": "D"
        }
      ]
    },
    {
      "title": "GC Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum{job=\"$job\"}[$__rate_interval])",
          "legendFormat": "{{kind}} duration/s",
          "refId": "A"
        },
        {
          "expr": "rate(nodejs_gc_duration_seconds_count{job=\"$job\"}[$__rate_interval])",
          "legendFormat": "{{kind}} runs/s",
          "refId": "B"
        }
      ]
    },

    {
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "pointSize": 5,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"$job\"}",
          "legendFormat": "Mean Lag",
          "refId": "A"
        },
        {
          "expr": "nodejs_eventloop_lag_p99_seconds{job=\"$job\"}",
          "legendFormat": "p99 Lag",
          "refId": "B"
        },
        {
          "expr": "nodejs_eventloop_lag_p50_seconds{job=\"$job\"}",
          "legendFormat": "p50 Lag",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Active Handles & Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "nodejs_active_handles_total{job=\"$job\"}",
          "legendFormat": "Active Handles",
          "refId": "A"
        },
        {
          "expr": "nodejs_active_requests_total{job=\"$job\"}",
          "legendFormat": "Active Requests",
          "refId": "B"
        }
      ]
    },

    {
      "title": "BullMQ Jobs by State",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": { "mode": "normal" },
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "waiting" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "yellow", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "active" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "delayed" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "blue", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "completed" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "super-light-green", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "bullmq_jobs{job=\"$job\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "BullMQ Queue Depth",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true
      },
      "targets": [
        {
          "expr": "bullmq_jobs{job=\"$job\"}",
          "legendFormat": "{{queue}} — {{state}}",
          "refId": "A",
          "instant": true
        }
      ]
    }
  ]
}

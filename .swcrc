{
  "$schema": "https://json.schemastore.org/swcrc",
  "exclude": "node_modules/",
  "sourceMaps": true,
  "isModule": true,
  "module": {
    "type": "nodenext"
  },
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "target": "esnext",
    "baseUrl": "./"
  }
}
